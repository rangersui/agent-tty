#!/usr/bin/env python3
"""k.py -- local token wrapper for the installed k command.

TCP clients normally discover the daemon token from private daemon.json
metadata, so this wrapper is not needed for normal use.

For debugging or unusual shells, start the daemon with --show-token:

    k daemon --show-token
    set K_TOKEN=abc123...

Copy that token into K_TOKEN below, and set K_PORT to match. Save this file as
k.py. Then use the wrapper for short local commands:

    python k.py ls
    python k.py new default
    python k.py run default "2+2"
    python k.py attach default

In AF_UNIX mode, the daemon listens on /tmp/k.sock by default.  Installed
commands are already short:

    k ls

Why this file exists:
  k normally discovers TCP daemon metadata automatically from daemon.json.  This
  wrapper is only a fixed-token debug/convenience path: it supplies K_TOKEN and
  K_PORT for each local command, then delegates to the installed k entry point.

Security:
  k.py contains a live daemon token.  It is intentionally listed in .gitignore.
  Keep the filled-in wrapper local.
"""
import os, sys, subprocess

# Paste the token from `k daemon --show-token` stderr output here.
K_TOKEN = "PASTE_TOKEN_HERE"

# The TCP port the daemon listens on (default 7399).
K_PORT = "7399"

here = os.path.dirname(os.path.abspath(__file__))
os.environ["K_TOKEN"] = K_TOKEN
os.environ["K_PORT"] = K_PORT

cmd = ["k"] + sys.argv[1:]
try:
    sys.exit(subprocess.call(cmd))
except FileNotFoundError:
    print("ERR installed 'k' command not found; run: python -m pip install agent-tty",
          file=sys.stderr)
    sys.exit(1)
